---
// BaseLayout.astro — 全站共用布局
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// 计算当前页面的相对路径用于导航高亮
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — 老李的数字花园</title>
  <meta name="description" content={description || '老李的播客笔记 & 精读笔记'} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- 字体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg: #faf9f6;
      --bg-card: #ffffff;
      --text: #1a1a2e;
      --text-muted: #6b7280;
      --accent: #2563eb;
      --accent-hover: #1d4ed8;
      --border: #e5e7eb;
      --tag-bg: #f0f4ff;
      --tag-text: #3b5998;
      --radius: 8px;
      --max-width: 720px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f1117;
        --bg-card: #1a1b23;
        --text: #e5e7eb;
        --text-muted: #9ca3af;
        --accent: #60a5fa;
        --accent-hover: #93bbfd;
        --border: #2d2d3a;
        --tag-bg: #1e293b;
        --tag-text: #93bbfd;
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.8;
      min-height: 100vh;
    }

    header {
      border-bottom: 1px solid var(--border);
      padding: 1.5rem 1rem;
      position: sticky;
      top: 0;
      background: var(--bg);
      backdrop-filter: blur(12px);
      z-index: 10;
    }

    nav {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav a {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
    }

    nav .brand {
      font-size: 1.25rem;
      font-weight: 700;
    }

    nav .brand span { color: var(--accent); }

    nav .links { display: flex; gap: 1.5rem; }

    nav .links a {
      font-size: 0.9rem;
      color: var(--text-muted);
      transition: color 0.2s;
    }

    nav .links a:hover,
    nav .links a.active {
      color: var(--accent);
    }

    main {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
    }

    footer {
      text-align: center;
      padding: 2rem 1rem;
      color: var(--text-muted);
      font-size: 0.85rem;
      border-top: 1px solid var(--border);
    }

    /* 文章列表 */
    .post-list { list-style: none; display: flex; flex-direction: column; gap: 1.25rem; }

    .post-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: border-color 0.2s, transform 0.15s;
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .post-card:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }

    .post-card time {
      font-size: 0.8rem;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
    }

    .post-card h2 {
      font-size: 1.2rem;
      margin: 0.4rem 0 0.5rem;
      line-height: 1.4;
    }

    .post-card p {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .post-card .tags {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }

    .tag {
      font-size: 0.75rem;
      background: var(--tag-bg);
      color: var(--tag-text);
      padding: 0.15em 0.6em;
      border-radius: 12px;
      font-weight: 500;
    }

    .category-badge {
      display: inline-block;
      font-size: 0.75rem;
      background: var(--accent);
      color: white;
      padding: 0.15em 0.6em;
      border-radius: 4px;
      font-weight: 600;
      margin-right: 0.5rem;
      vertical-align: middle;
    }

    /* 文章详情 */
    article { margin-top: 1rem; }
    
    article h1 {
      font-size: 2rem;
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }

    article .meta {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin-bottom: 2rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    article h2 {
      font-size: 1.4rem;
      margin: 2rem 0 0.75rem;
      padding-bottom: 0.3rem;
      border-bottom: 2px solid var(--border);
    }

    article h3 { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; }
    article p { margin: 0.75rem 0; }
    article blockquote {
      border-left: 3px solid var(--accent);
      padding: 0.5rem 1rem;
      margin: 1rem 0;
      background: var(--tag-bg);
      border-radius: 0 var(--radius) var(--radius) 0;
      color: var(--text-muted);
    }
    article ul, article ol { padding-left: 1.5rem; margin: 0.75rem 0; }
    article li { margin: 0.3rem 0; }
    article code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85em;
      background: var(--tag-bg);
      padding: 0.1em 0.35em;
      border-radius: 3px;
    }
    article pre {
      background: #1e1e2e;
      color: #cdd6f4;
      padding: 1rem;
      border-radius: var(--radius);
      overflow-x: auto;
      margin: 1rem 0;
      font-size: 0.85rem;
    }
    article pre code {
      background: transparent;
      padding: 0;
    }
    article strong { color: var(--accent); }
    article hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

    /* 搜索 */
    .search-bar {
      margin-bottom: 2rem;
    }

    .search-bar input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-card);
      color: var(--text);
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-bar input:focus { border-color: var(--accent); }

    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-muted);
    }

    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }

    /* 标签筛选 */
    .tag-filter {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .tag-filter .tag {
      cursor: pointer;
      border: 1px solid transparent;
      transition: all 0.2s;
    }
    .tag-filter .tag.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    /* 响应式 */
    @media (max-width: 600px) {
      nav { flex-direction: column; gap: 0.5rem; }
      article h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="brand">🌿 老李的<span>数字花园</span></a>
      <div class="links">
        <a href="/" class={currentPath === '/' ? 'active' : ''}>笔记</a>
        <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>标签</a>
        <a href="/about" class={currentPath === '/about' ? 'active' : ''}>关于</a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>🌱 种一棵树最好的时间是十年前，其次是现在。</p>
  </footer>
</body>
</html>
