---
// 首页 — 笔记列表
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const base = import.meta.env.BASE_URL;

// 获取所有标签
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();

// 读取 URL 参数用于筛选
const url = new URL(Astro.request.url);
const selectedTag = url.searchParams.get('tag') || '';
const searchQuery = url.searchParams.get('q') || '';
const selectedCategory = url.searchParams.get('cat') || '';

const filteredPosts = posts.filter(p => {
  if (selectedTag && !p.data.tags.includes(selectedTag)) return false;
  if (selectedCategory && p.data.category !== selectedCategory) return false;
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    const title = p.data.title.toLowerCase();
    const desc = p.data.description.toLowerCase();
    const content = p.body?.toLowerCase() || '';
    if (!title.includes(q) && !desc.includes(q) && !content.includes(q)) return false;
  }
  return true;
});
---

<BaseLayout title={searchQuery ? `搜索: ${searchQuery}` : '笔记'}>
  <!-- 搜索 -->
  <div class="search-bar">
    <input
      type="text"
      id="search"
      placeholder="🔍 搜索笔记…"
      value={searchQuery}
      autocomplete="off"
    />
  </div>

  <!-- 分类筛选 -->
  <div class="tag-filter">
    <a href={base} class={`tag ${!selectedCategory ? 'active' : ''}`}>全部</a>
    <a href={`${base}?cat=播客笔记`} class={`tag ${selectedCategory === '播客笔记' ? 'active' : ''}`}>🎧 播客笔记</a>
    <a href={`${base}?cat=精读笔记`} class={`tag ${selectedCategory === '精读笔记' ? 'active' : ''}`}>📖 精读笔记</a>
  </div>

  <!-- 标签筛选 -->
  <div class="tag-filter">
    {allTags.map(tag => (
      <a href={`${base}?tag=${tag}${selectedCategory ? `&cat=${selectedCategory}` : ''}`}
         class={`tag ${selectedTag === tag ? 'active' : ''}`}>
        {tag}
      </a>
    ))}
  </div>

  <!-- 文章列表 -->
  {
    filteredPosts.length === 0 ? (
      <div class="empty-state">
        <div class="icon">{searchQuery ? '🔍' : '📭'}</div>
        <p>{searchQuery ? `没有找到包含"${searchQuery}"的笔记` : '暂无笔记'}</p>
      </div>
    ) : (
      <ul class="post-list">
        {filteredPosts.map(post => (
          <li>
            <a href={`/posts/${post.slug}`} class="post-card">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="category-badge">{post.data.category}</span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="tags">
                {post.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<script>
  // 客户端搜索 — 回车跳转
  const input = document.getElementById('search') as HTMLInputElement;
  if (input) {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = input.value.trim();
        if (q) {
          const params = new URLSearchParams(window.location.search);
          params.set('q', q);
          window.location.search = params.toString();
        } else {
          const params = new URLSearchParams(window.location.search);
          params.delete('q');
          window.location.search = params.toString();
        }
      }
    });
  }
</script>
