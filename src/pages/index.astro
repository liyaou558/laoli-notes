---
// 首页 — 公众号文章列表
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const base = import.meta.env.BASE_URL;
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();

const url = new URL(Astro.request.url);
const selectedTag = url.searchParams.get('tag') || '';
const searchQuery = url.searchParams.get('q') || '';
const selectedCategory = url.searchParams.get('cat') || '';

const filteredPosts = posts.filter(p => {
  if (selectedTag && !p.data.tags.includes(selectedTag)) return false;
  if (selectedCategory && p.data.category !== selectedCategory) return false;
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    const title = p.data.title.toLowerCase();
    const desc = p.data.description.toLowerCase();
    const body = p.body?.toLowerCase() || '';
    if (!title.includes(q) && !desc.includes(q) && !body.includes(q)) return false;
  }
  return true;
});

function getPodcastEmoji(title: string) {
  if (title.includes('半拿铁')) return '☕';
  if (title.includes('42章经')) return '🔢';
  if (title.includes('硅谷101')) return '💻';
  if (title.includes('张小珺')) return '🎙️';
  if (title.includes('罗永浩')) return '🎤';
  return '📻';
}

function getReadingEmoji(title: string) {
  return '📖';
}

function getCategoryEmoji(post: any) {
  if (post.data.category === '播客笔记') return getPodcastEmoji(post.data.podcast || '');
  return getReadingEmoji(post.data.title);
}
---

<BaseLayout title={searchQuery ? `"${searchQuery}" 的搜索结果` : '笔记'} description="老李的播客笔记 & 精读笔记">
  <div class="search-wrap">
    <input
      type="text" id="search" placeholder="搜索笔记..."
      value={searchQuery} autocomplete="off"
    />
  </div>

  <div class="filter-row">
    <a href={base} class={`filter-btn ${!selectedCategory ? 'active' : ''}`}>全部</a>
    <a href={`${base}?cat=播客笔记`} class={`filter-btn ${selectedCategory === '播客笔记' ? 'active' : ''}`}>🎧 播客</a>
    <a href={`${base}?cat=精读笔记`} class={`filter-btn ${selectedCategory === '精读笔记' ? 'active' : ''}`}>📖 精读</a>
  </div>

  <div class="filter-row">
    {allTags.map(tag => (
      <a href={`${base}?tag=${tag}${selectedCategory ? `&cat=${selectedCategory}` : ''}`}
         class={`filter-btn ${selectedTag === tag ? 'active' : ''}`}>
        {tag}
      </a>
    ))}
  </div>

  {
    filteredPosts.length === 0 ? (
      <div class="empty">
        {searchQuery ? `未找到包含「${searchQuery}」的笔记` : '暂无笔记'}
      </div>
    ) : (
      <ul class="post-list">
        {filteredPosts.map(post => (
          <li>
            <a href={`${base}posts/${post.slug}`} class="post-card">
              <div class="post-card-header">
                <div class={`post-card-avatar ${post.data.category === '播客笔记' ? 'podcast' : 'reading'}`}>
                  {getCategoryEmoji(post)}
                </div>
                <div class="post-card-meta">
                  <div class="post-card-author">
                    {post.data.podcast || post.data.category}
                    {post.data.guests ? ` · ${post.data.guests}` : ''}
                  </div>
                  <div class="post-card-time">
                    {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                    {post.data.duration ? ` · ${post.data.duration}` : ''}
                  </div>
                </div>
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="post-card-footer">
                <div class="post-card-tags">
                  {post.data.tags.slice(0, 4).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <span class="post-card-arrow">→</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<script>
  const input = document.getElementById('search') as HTMLInputElement;
  if (input) {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = input.value.trim();
        const params = new URLSearchParams(window.location.search);
        if (q) params.set('q', q);
        else params.delete('q');
        window.location.search = params.toString();
      }
    });
  }
</script>
